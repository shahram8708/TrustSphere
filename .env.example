# Flask secret key. Generate a production value with secrets.token_hex(32).
SECRET_KEY=change-this-development-secret

# SQLite database path used by Flask SQLAlchemy.
DATABASE_URL=sqlite:///trustsphere.db

# Redis connection used by rate limiting and Celery.
REDIS_URL=redis://localhost:6379/0

# Celery broker URL. Usually the same value as REDIS_URL.
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend URL. Usually the same value as REDIS_URL.
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# SMTP server hostname.
MAIL_SERVER=smtp.gmail.com

# SMTP port for TLS.
MAIL_PORT=587

# Enable TLS for outbound mail.
MAIL_USE_TLS=True

# SMTP email address.
MAIL_USERNAME=

# SMTP app password.
MAIL_PASSWORD=

# Base64 encoded 32 byte key for field encryption.
ENCRYPTION_MASTER_KEY=

# Secret used to sign JWT tokens.
JWT_SECRET_KEY=change-this-jwt-secret

# Flask runtime environment.
FLASK_ENV=development

# Enable MaxMind GeoIP lookups when configured.
GEOIP_ENABLED=False

# Default institution name for local development.
DEFAULT_INSTITUTION_NAME=TrustSphere Demo Bank

# Default platform admin login email.
DEFAULT_ADMIN_EMAIL=admin@trustsphere.com

# Default platform admin login password.
DEFAULT_ADMIN_PASSWORD=Admin@TrustSphere2026
